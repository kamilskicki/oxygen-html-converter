{
  "name": "oxygen-html-converter-core",
  "private": true,
  "description": "Node-based frontend behavior tests for Oxygen HTML Converter core plugin.",
  "scripts": {
    "benchmark:conversion": "php scripts/benchmark-conversion.php",
    "check:release-hygiene": "php scripts/check_release_hygiene.php",
    "test:js": "node tests/js/run-tests.cjs",
    "test:php": "composer test",
    "test:fixtures": "node tests/live/run-fixture-baseline.cjs",
    "test:fixtures:nested": "node tests/live/run-fixture-baseline.cjs --include-nested",
    "test:fixtures:local": "php tests/live/run-local-fixture-audit.php",
    "test:live": "node tests/live/run-live-gate.cjs",
    "test:live:maximus": "node tests/live/run-live-gate.cjs --fixture=Maximus/maximus_transformacja_domu/code.html",
    "build:site:maximus": "node tests/live/run-maximus-site-build.cjs",
    "import:site:maximus-v2": "node tests/live/run-maximus-v2-import.cjs",
    "test:live:maximus:windpress": "node tests/live/run-live-gate.cjs --class-mode=windpress --fixture=Maximus/maximus_transformacja_domu/code.html",
    "test:live:artifact": "node tests/live/run-live-gate.cjs --skip-sync",
    "test:visual": "node tests/live/run-visual-review.cjs",
    "test:visual:maximus": "node tests/live/run-visual-review.cjs --fixture=Maximus/maximus_transformacja_domu/code.html",
    "test:visual:maximus:windpress": "node tests/live/run-visual-review.cjs --class-mode=windpress --fixture=Maximus/maximus_transformacja_domu/code.html",
    "test:maximus:matrix": "node tests/live/run-maximus-matrix.cjs",
    "test:maximus:matrix:full-live": "node tests/live/run-maximus-matrix.cjs --live=all",
    "install:zip": "node tests/live/install-zip-via-admin.cjs",
    "test:artifact": "npm run install:zip && npm run test:fixtures && npm run test:live:artifact && npm run test:visual",
    "sync:docker": "node tests/live/sync-docker-plugin.cjs",
    "build:zip": "php scripts/build-release.php",
    "measure:fallback-css": "php scripts/measure-fallback-css.php --output=artifacts/fallback-css-baseline.md",
    "release:verify": "php scripts/release_verify.php",
    "release:verify:live": "php scripts/release_verify.php --with-live",
    "lint:phpcs": "composer lint:phpcs",
    "lint:phpstan": "composer lint:phpstan",
    "i18n:make-pot": "wp i18n make-pot . languages/oxygen-html-converter.pot --domain=oxygen-html-converter --exclude=node_modules,vendor,tests,tests/live,artifacts,.git,.worktrees",
    "i18n:make-pot:docker": "docker run --rm -v %cd%:/app -w /app wordpress:cli wp i18n make-pot . languages/oxygen-html-converter.pot --domain=oxygen-html-converter --exclude=node_modules,vendor,tests,tests/live,artifacts,.git,.worktrees --allow-root",
    "check": "npm run check:release-hygiene && npm run test:js && composer lint:phpcs && composer lint:phpstan && composer test",
    "test": "npm run test:js && npm run test:php"
  }
}
