{
  "name": "skicu/oxygen-html-converter",
  "description": "Convert HTML content to Oxygen Builder JSON format.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Skicu"
    }
  ],
  "autoload": {
    "psr-4": {
      "OxyHtmlConverter\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OxyHtmlConverter\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^1.12",
    "squizlabs/php_codesniffer": "^3.11",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "scripts": {
    "test": "phpunit --testsuite Unit",
    "test:legacy": "phpunit --configuration phpunit.legacy.xml",
    "test:contracts": "phpunit tests/Unit/Compatibility/InstalledBuilderContractsTest.php",
    "lint:phpcs": "phpcs --runtime-set ignore_warnings_on_exit 1 --standard=phpcs.xml.dist",
    "lint:phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
    "check": [
      "@test",
      "@lint:phpcs",
      "@lint:phpstan"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
